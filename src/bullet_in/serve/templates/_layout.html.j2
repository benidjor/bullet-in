{% macro facet_opts(group, items) %}
  {% for it in items %}
  <label class="opt"><input type="checkbox" data-group="{{ group }}" data-value="{{ it.value }}" data-tier="{{ it.tier }}"> {{ it.label }} <span class="ct">{{ it.count }}</span></label>
  {% endfor %}
{% endmacro -%}
{% macro facet_block(group, data) %}
<div class="facetgroup">
  {% for g in data.initial %}
  <div class="tierhead">{{ g.heading }}</div>
  {{ facet_opts(group, g["items"]) }}
  {% endfor %}
  {% for st in data.stages %}
  <div class="morestage" hidden>
    {% for g in st.groups %}
    <div class="tierhead">{{ g.heading }}</div>
    {{ facet_opts(group, g["items"]) }}
    {% endfor %}
    {% if st.unregistered %}
    <div class="unreghead"><span>미등재</span></div>
    {{ facet_opts(group, st.unregistered) }}
    {% endif %}
  </div>
  <button class="morebtn" type="button" hidden>{{ st.label }}</button>
  {% endfor %}
</div>
{% endmacro -%}
<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="referrer" content="no-referrer">
<title>{% block title %}Bullet-in{% endblock %}</title>
<script>(function(){try{var t=localStorage.getItem('theme');if(t)document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
<link rel="stylesheet" href="{{ root }}style.css">
</head>
<body>
<div class="topbar"><div class="inner">
  <button class="iconbtn hamb" id="hambBtn" aria-label="필터 열기">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
  </button>
  <a class="logo" href="{{ root }}index.html"><span class="crest"></span>Bullet-in</a>
  <nav class="nav">
    <a class="{{ 'active' if active == 'home' else '' }}" href="{{ root }}index.html">홈</a>
    <a class="{{ 'active' if active == 'about' else '' }}" href="{{ root }}about.html">소개</a>
  </nav>
  <label class="search">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
    <input id="q" placeholder="선수·구단·이적 키워드 검색">
  </label>
  <span class="spacer"></span>
  {% if active == 'home' %}
  <select class="sortsel" id="sortSel" title="정렬 — 조회순은 이 기기에서 연 기사 기록 기준">
    <option value="latest" selected>최신순</option>
    <option value="confidence">신뢰도순</option>
    <option value="views">조회순</option>
  </select>
  {% endif %}
  <button class="iconbtn" id="themeBtn" aria-label="라이트·다크 전환">
    <svg class="ic-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
    <svg class="ic-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"/></svg>
  </button>
</div></div>

<div class="scrim" id="scrim"></div>

{% block band %}{% endblock %}

<div class="shell{{ ' solo' if about_page }}">
  {% if not about_page %}
  <aside class="side">
    <h4>팀</h4>
    <label class="opt"><input type="checkbox" data-group="team" data-value="arsenal" checked> Arsenal <span class="ct">{{ facets.team.get('arsenal', 0) }}</span></label>

    <div class="grp" data-grp="stage">
      <button class="grphead" type="button"><h4>영입 단계</h4><span class="caret">▾</span></button>
      <div class="grpbody">
      {% for sg in facets.stage_groups %}
      <label class="opt"><input type="checkbox" data-group="stage" data-value="{{ sg.value }}"> {{ sg.label }} <span class="ct">{{ sg.count }}</span></label>
      {% endfor %}
      <label class="opt"><input type="checkbox" data-group="bucket" data-value="other"> 기타 <span class="ct">{{ facets.other or 0 }}</span></label>
      </div>
    </div>

    <div class="grp" data-grp="tier">
      <button class="grphead" type="button"><h4>공신력</h4><span class="caret">▾</span></button>
      <div class="grpbody">
      <label class="opt"><input type="checkbox" data-group="tier" data-value="all" checked> 전체 <span class="ct">{{ facets.total }}</span></label>
      {% for t in facets.tiers %}{% if t.count %}
      <label class="opt"><input type="checkbox" data-group="tier" data-value="{{ t.key }}"> {{ t.reader }} <span class="ct">{{ t.count }}</span></label>
      {% endif %}{% endfor %}
      </div>
    </div>

    <div class="grp collapsed" data-grp="outlet">
      <button class="grphead" type="button"><h4>소스 (언론사)</h4><span class="caret">▾</span></button>
      <div class="grpbody">{{ facet_block('outlet', facets.outlets) }}</div>
    </div>

    <div class="grp collapsed" data-grp="journalist">
      <button class="grphead" type="button"><h4>기자</h4><span class="caret">▾</span></button>
      <div class="grpbody">{{ facet_block('journalist', facets.journalists) }}</div>
    </div>

    <div class="fstatus" id="fstatus">전체 표시</div>
    <div class="actions">
      <button class="btn reset" id="resetBtn">초기화</button>
      <button class="btn apply" id="applyBtn">필터 적용</button>
    </div>
  </aside>
  {% endif %}

  <main>{% block content %}{% endblock %}</main>
</div>

<script src="{{ root }}app.js"></script>
</body>
</html>
